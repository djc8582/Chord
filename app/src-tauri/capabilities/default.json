{
  "identifier": "default",
  "description": "Default capabilities for the Chord app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:default",
    "core:window:allow-set-title",
    "core:webview:default",
    "core:app:default",
    "core:app:allow-version"
  ]
}
